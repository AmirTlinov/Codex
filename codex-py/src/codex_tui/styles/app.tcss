/* Codex TUI - Minimal ASCII Style */

/* Main layout */
Screen {
    background: $surface;
}

#main {
    layout: vertical;
    height: 1fr;
}

/* Header - simple line */
Header {
    dock: top;
    height: 1;
    background: $surface;
    color: $text-muted;
}

/* Footer - simple line */
Footer {
    dock: bottom;
    height: 1;
    background: $surface;
}

/* Chat area */
ChatWidget {
    height: 1fr;
    padding: 1 2;
}

/* Composer - minimal border */
Composer {
    dock: bottom;
    height: auto;
    min-height: 1;
    max-height: 8;
    border-top: solid $primary-muted;
    padding: 0 1;
    margin: 0;
}

Composer:focus {
    border-top: solid $primary;
}

/* Messages - no margins, compact */
MessageWidget {
    height: auto;
    margin: 0 0 1 0;
}

CommandWidget {
    height: auto;
    margin: 0 0 1 0;
}

ThinkingWidget {
    height: auto;
    margin: 0;
}

UsageWidget {
    height: auto;
    margin: 0;
}

/* Approval Overlay - simple */
ApprovalOverlay {
    align: center middle;
}

ApprovalOverlay > Container {
    width: 70%;
    max-width: 80;
    height: auto;
    max-height: 70%;
    background: $surface;
    border: ascii $primary;
    padding: 1;
}

ApprovalOverlay #content {
    height: auto;
    max-height: 50%;
    overflow-y: auto;
}

ApprovalOverlay #buttons {
    layout: horizontal;
    height: auto;
    align: center middle;
    margin-top: 1;
}

ApprovalOverlay Button {
    margin: 0 1;
    min-width: 10;
}

/* Diff View - minimal */
DiffView {
    height: 1fr;
    padding: 1;
}

DiffOverlay {
    align: center middle;
}

DiffOverlay > Container {
    width: 85%;
    height: 85%;
    background: $surface;
    border: ascii $primary;
}

DiffOverlay #diff-header {
    dock: top;
    height: 1;
    padding: 0 1;
}

DiffOverlay #diff-content {
    height: 1fr;
    padding: 1;
}

DiffOverlay #diff-footer {
    dock: bottom;
    height: 1;
    layout: horizontal;
    align: center middle;
    padding: 0 1;
}

/* Shell Panel - minimal */
ShellPanel {
    height: 100%;
    border: ascii $primary;
}

ShellPanel #shell-actions {
    dock: bottom;
    height: 1;
    layout: horizontal;
    align: center middle;
    padding: 0 1;
}

/* Shell Log Overlay */
ShellLogOverlay {
    width: 75%;
    height: 75%;
    background: $surface;
    border: ascii $primary;
    padding: 1;
}

ShellLogOverlay #log-content {
    height: 1fr;
    overflow-y: auto;
    padding: 1;
}

ShellLogOverlay #log-header {
    dock: top;
    height: 1;
    padding: 0 1;
}
