/* Codex TUI - Claude Code Style */

Screen {
    background: $surface;
}

#main {
    layout: vertical;
    height: 1fr;
}

/* Minimal header */
Header {
    dock: top;
    height: 1;
    background: $surface;
}

/* Minimal footer with hints */
Footer {
    dock: bottom;
    height: 1;
}

/* Chat area - generous padding */
ChatWidget {
    height: 1fr;
    padding: 0 1;
}

/* Compact messages */
MessageWidget {
    height: auto;
    margin: 0;
}

CommandWidget {
    height: auto;
    margin: 0;
}

ThinkingWidget {
    height: auto;
    margin: 0;
}

UsageWidget {
    height: auto;
    margin: 0;
}

/* Composer at bottom with separator */
Composer {
    dock: bottom;
    height: auto;
    min-height: 1;
    max-height: 10;
    border-top: solid $primary-darken-2;
    padding: 0 1;
    margin: 0;
}

/* Approval overlay - clean box */
ApprovalOverlay {
    align: center middle;
}

ApprovalOverlay > Container {
    width: 70%;
    max-width: 80;
    height: auto;
    max-height: 70%;
    background: $surface;
    border: round $primary;
    padding: 1;
}

ApprovalOverlay #buttons {
    layout: horizontal;
    height: auto;
    align: center middle;
    margin-top: 1;
}

ApprovalOverlay Button {
    margin: 0 1;
}

/* Diff overlay */
DiffOverlay {
    align: center middle;
}

DiffOverlay > Container {
    width: 85%;
    height: 85%;
    background: $surface;
    border: round $primary;
}

DiffOverlay #diff-content {
    height: 1fr;
    padding: 1;
}

/* Shell panel */
ShellPanel {
    height: 100%;
    border: round $primary;
}

ShellLogOverlay {
    width: 75%;
    height: 75%;
    background: $surface;
    border: round $primary;
    padding: 1;
}

ShellLogOverlay #log-content {
    height: 1fr;
    overflow-y: auto;
}
